{
  "version": 2,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/style.css", "destination": "/public/style.css" },
    { "source": "/app.js", "destination": "/public/app.js" },
    { "source": "/((?!_vercel/).*)", "destination": "/public/index.html" }
  ]
}
